                                                (BITOR
                                                  (if (AND (NOT #old_demo) #chk_demo) %1011110 %110110)
                                                  (if (AND (NOT #old_mcp) #chk_mcp)   %1010111 %1010110)
                                                )
                                                (if (AND (NOT #old_source) #chk_source) %1110110 %1010110)
                                              )
                          )
     )
     (set #defaultmask %0000000)
