                       (if (<> (BITAND #chk_htmldocs (BITNOT #old_htmldocs)) 0)
                         %100
                         %000
                       )
                     )
                     #chk_docs
                   )
     )
     (set #defaultmask (if #update (BITAND %111 (BITNOT #old_docs)) (if (IN #docmask 1) %010 (if (IN #docmask 0) %001 %100)) ))
     (P_AskDocFormats)
     (set #install_docs #docmask)
    )
    (set #install_docs 0)
  )

  (if (IN #install_docs 0)
