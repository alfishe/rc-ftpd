 (procedure P_BitToLanguage
  (set #i 0)
  (set #bitmask %11111111111111111111111110)
  (while (AND (< #i 25) (NOT (IN #langmask #i)))
    (
     (set #bitmask (BITOR (shiftleft #bitmask 1) %00000000000000000000000001))
     (set #i (+ #i 1))
    )
  )
  (set #langmask (BITAND #langmask #bitmask))
  (set #lang (select #i "english" "deutsch" "franчais" "espaёol" "portuguъs" "dansk" "italiano" "nederlands" "norsk" "svenska" "polski" "suomi" "magyar" "greek" "esperanto" "tќrkчe" "latina" "russian" "Уeгtina" "catalonian" "Croatian" "srpski" "Slovak" "slovensko" "portuguъs-brasil" ""))
 )

 (procedure P_GetVersion
  (set #vernum (getversion (cat #file)))
  (set #ver (/ #vernum 65536))
  (set #rev (- #vernum (* #ver 65536)))
 )

 (procedure P_CompareVersions
  (if (< #ver #ver2)
    (set #result -1)
    (if (> #ver #ver2)
      (set #result 1)
      (if (< #rev #rev2)
        (set #result -1)
        (if (> #rev #rev2)
          (set #result 1)
          (set #result 0)
        )
      )
    )
  )
 )

 (procedure P_GetOSVersionStr
  (set #i 0)
  (while (<> #ver (select #i 30 31 32 33 34 36 37 38 39 40 #ver))
    (set #i (+ #i 1))
  )
  (set #str (select #i "1.0" "1.1 NTSC" "1.1 PAL" "1.2" "1.3" "2.0pre" "2.0" "2.1" "3.0" "3.1" #unknown))
 )

 (procedure P_GetOSVersion
  (set #file "libs:version.library")
  (P_GetVersion)
  (set #os_ver #ver)
  (set #os_rev #rev)

  (P_GetOSVersionStr)
  (set #os_str #str)
 )

 (procedure P_GetCPUFPU
  (set #cpu_str (database "cpu"))
  (set #cpu 0)
  (while (<> #cpu_str (select #cpu "68000" "68010" "68020" "68030" "68040""68060" #cpu))
    (set #cpu (+ #cpu 1))
  )
  (if (= #cpu 6)
    (
     (set #cpu -1)
     (set #cpu_str #unknown)
    )
  )

  (if @installer-version
    (
     (set #fpu_str (database "fpu"))
     (set #fpu 0)
     (while (<> #fpu_str (select #fpu "NOFPU" "68881" "68882" "FPU40" #fpu_str))
       (set #fpu (+ #fpu 1))
     )
     (if (= #fpu 4)
       (
        (set #fpu -1)
        (set #fpu_str #unknown)
       )
     )
    )
    (
     (set #fpu -1)
     (set #fpu_str #unknown)
    )
  )
 )

