struct FtpdBase
{
	struct MinList		 fb_Servers;
	struct MinList		 fb_Users;			// Prefs
	struct MinList		 fb_Paths;			// Prefs
	u_long				 fb_Flags;			// Prefs
	u_long				 fb_MaxUsers;		// Prefs
	u_long				 fb_MaxCPS;			// Prefs
	u_long				 fb_Timeout;		// Prefs
	char					*fb_List;			// Prefs
};

#define	FTPD_NO_ACCEPT		(1<<0)		// Is server open?
#define	FTPD_IGNORE_NOOP	(1<<1)		// Can we idle?
#define	FTPD_MESSAGE		(1<<2)		// Auto-type .message files on CWD.
#define	FTPD_COMMENT		(1<<3)		// Auto-set the comment of all uploaded files.

struct FtpdServer
{
	struct MinNode		 fs_Node;
	struct MinList		 fs_Connections;
	struct Library		*fs_SocketBase;
	struct Library		*fs_FTPdBase;
	struct MsgPort		*fs_Port;
	u_char				 fs_Count;
	u_char				 fs_Flags;
};

struct FtpdConnection
{
	struct MinNode		 fc_Node;
	long					 fc_FD;
	u_long				 fc_Flags;
	u_long				 fc_Port;
	char					*fc_User;
	char					*fc_Path;
	char					*fc_Host;
	char					*fc_Inbuf;
	char					*fc_Outbuf;
	struct sockaddr_in fc_Data;
};

struct FtpdUser
{
	struct MinNode		 fu_Node;
	char					*fu_Name;			// Prefs
	char					*fu_Password;		// Prefs
	char					*fu_Group;			// Prefs
	u_long				 fu_Flags;			// Prefs
	u_short				 fu_MaxUsers;		// Prefs
	u_short				 fu_NowUsers;
	long					 fu_Xfer;			// Prefs	±(X * fu_Ratio)
	long					 fu_Ratio;			// Prefs 0 = Not used
};

struct FtpdPath
{
	struct MinNode		 fa_Node;
	char					*fa_Owner;			// Prefs, ie. "root"
	char					*fa_Group;			// Prefs, ie. "admin"
	char					*fa_Path;			// Prefs, ie. "Internet:HTTP/" (relative to virtual parent)
	char					*fa_Virtual;		// Prefs, ie. "/"
	u_short				 fa_OwnerAccess;	// Prefs
	u_short				 fa_GroupAccess;	// Prefs
	u_short				 fa_GuestAccess;	// Prefs
	u_short				 fa_Flags;			// Prefs
};

#define	FTPD_PATH_NEW			(1<<0)	// STOR + RNTO
#define	FTPD_PATH_APPEND		(1<<1)	// APPE
#define	FTPD_PATH_REMDIR		(1<<2)	// RMD
#define	FTPD_PATH_RENAME		(1<<3)	// RNFR + RNTO
#define	FTPD_PATH_MAKEDIR		(1<<4)	// MKD
#define	FTPD_PATH_DELETE		(1<<5)	// DELE
#define	FTPD_PATH_READ			(1<<6)	// RETR
#define	FTPD_PATH_WRITE		(1<<7)	// STOR + APPE
#define	FTPD_PATH_CD			(1<<8)	// CWD
#define	FTPD_PATH_LIST			(1<<9)	// LIST

#define	FTPD_FLAG_SUBDIRS		(1<<0)	// Default ON, allows access to subdirs
#define	FTPD_FLAG_OVERRIDE	(1<<1)	// Default OFF, override AmigaOS flags

struct FtpdCommand
{
	struct MinNode		 fc_Node;
	char					*fc_Name;
	BOOL				  (*fc_Command)(struct FtpdConnection*);
	u_long				 fc_Flags;
	char					*fc_Notify;
	char					*fc_Sound;
};

#define	FTPD_CMD_NOLOG			(1<<0)	// Don't log me - ie. HELP
#define	FTPD_CMD_SECRET		(1<<1)	// Hide args in log - ie. PASS



